import os
import shutil

# Definição dos nomes das pastas
diretorio_origem = "pasta_importante"
diretorio_backup = "pasta_backup"

# Criação das pastas de teste caso elas não existam
os.makedirs(diretorio_origem, exist_ok=True)
os.makedirs(diretorio_backup, exist_ok=True)

# Criando 3 arquivos fictícios dentro da pasta importante para simular dados reais
for i in range(1, 4):
    with open(f"{diretorio_origem}/documento_{i}.txt", "w") as f:
        f.write(f"Conteúdo confidencial do documento {i}")

print("=== INICIANDO SISTEMA DE BACKUP AUTOMÁTICO ===")

# Listando os arquivos da pasta de origem
arquivos = os.listdir(diretorio_origem)

if not arquivos:
    print("A pasta de origem está vazia. Nada para copiar.")
else:
    for arquivo in arquivos:
        # Monta o caminho completo de origem e de destino
        caminho_origem = os.path.join(diretorio_origem, arquivo)
        caminho_destino = os.path.join(diretorio_backup, arquivo)
        
        # Realiza a cópia do arquivo usando a biblioteca shutil
        shutil.copy(caminho_origem, caminho_destino)
        print(f"✓ Cópia feita: {arquivo} -> enviado para {diretorio_backup}/")

print("\n[Sucesso] Todos os arquivos importantes foram salvos na pasta de backup!")