import json

# Dicionário de clientes simulado
clientes = {
    "cliente_1": {"nome": "Carlos Souza", "email": "carlos@email.com", "ativo": True},
    "cliente_2": {"nome": "Ana Costa", "email": "ana.costa@email.com", "ativo": False},
    "cliente_3": {"nome": "Mariana Lima", "email": "mariana@email.com", "ativo": True}
}

nome_arquivo_json = "clientes.json"

# 1. Salvando o dicionário no arquivo JSON
with open(nome_arquivo_json, "w", encoding="utf-8") as arquivo:
    # indent=4 serve para deixar o arquivo visualmente organizado
    json.dump(clientes, arquivo, indent=4, ensure_ascii=False)

print(f"Dados de clientes salvos em '{nome_arquivo_json}'.\n")

# 2. Carregando e exibindo os dados do arquivo JSON
with open(nome_arquivo_json, "r", encoding="utf-8") as arquivo:
    dados_carregados = json.load(arquivo)

print("--- Dados Carregados do JSON ---")
for chave, info in dados_carregados.items():
    print(f"ID: {chave} | Nome: {info['nome']} | E-mail: {info['email']} | Ativo: {info['ativo']}")