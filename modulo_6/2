def calcular_media(notas):
    """Calcula a média de uma lista de notas e verifica o status de aprovação."""
    if not notas:
        print("Nenhuma nota informada.")
        return

    media = sum(notas) / len(notas)
    
    print(f"\nMédia final: {media:.2f}")
    if media >= 7.0:
        print("Status: APROVADO(A)! 🎉")
    else:
        print("Status: REPROVADO(A). 📚")

# --- Testando a função ---
# Exemplo com 3 notas
notas_aluno = [8.5, 6.5, 7.0]
print(f"Notas do aluno: {notas_aluno}")
calcular_media(notas_aluno)