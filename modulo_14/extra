from django.shortcuts import render # type: ignore
from django.core.paginator import Paginator # type: ignore
from .models import Produto # type: ignore

def listar_produtos(request):
    query_busca = request.GET.get('busca', '')
    
    # Aplicação do filtro por nome (icontains ignora maiúsculas/minúsculas)
    if query_busca:
        lista_produtos = Produto.objects.filter(nome__icontains=query_busca).order_by('nome')
    else:
        lista_produtos = Produto.objects.all().order_by('nome')

    # Paginação: Limita a exibição a 5 itens por página
    paginador = Paginator(lista_produtos, 5)
    pagina_atual = request.GET.get('page')
    produtos_paginados = paginador.get_page(pagina_atual)

    contexto = {
        'produtos': produtos_paginados,
        'busca': query_busca
    }
    return render(request, 'produtos/listar_com_desafio.html', contexto)