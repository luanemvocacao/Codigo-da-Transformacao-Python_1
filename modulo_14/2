from flask import Flask, jsonify, request # type: ignore

app = Flask(__name__)

@app.route('/cadastrar', methods=['POST'])
def cadastrar_usuario_memoria():
    """Recebe os dados do usuário via payload JSON e valida a requisição."""
    # Captura os dados no formato JSON
    dados = request.get_json()
    
    # Validação estrutural dos campos obrigatórios
    if not dados or "nome" not in dados or "email" not in dados:
        return jsonify({
            "erro": "Bad Request",
            "mensagem": "Dados inválidos. Certifique-se de preencher 'nome' e 'email'."
        }), 400
        
    nome = dados["nome"]
    email = dados["email"]
    
    # Retorna uma simulação de sucesso confirmando os dados recebidos
    return jsonify({
        "mensagem": "Dados recebidos com sucesso via JSON (Validação OK)!",
        "usuario_recebido": {
            "nome": nome,
            "email": email
        }
    }), 200

if __name__ == "__main__":
    app.run(debug=True)