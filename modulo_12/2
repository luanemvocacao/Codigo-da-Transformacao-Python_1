import sqlite3

def rodar_crud():
    conexao = sqlite3.connect("empresa.db")
    cursor = conexao.cursor()
    
    print("=== INICIANDO OPERAÇÕES CRUD ===")

    # 1. INSERIR (Create)
    print("\n[C] - Inserindo registros de teste...")
    try:
        cursor.execute("INSERT INTO Clientes (nome, email) VALUES (?, ?)", ("Carlos Souza", "carlos@email.com"))
        cursor.execute("INSERT INTO Clientes (nome, email) VALUES (?, ?)", ("Ana Costa", "ana@email.com"))
        conexao.commit()
        print("✓ Registros adicionados.")
    except sqlite3.IntegrityError:
        print("ℹ Os registros de teste já existem no banco.")

    # 2. CONSULTAR (Read)
    print("\n[R] - Consultando dados cadastrados:")
    cursor.execute("SELECT * FROM Clientes")
    for linha in cursor.fetchall():
        print(f"   ID: {linha[0]} | Nome: {linha[1]} | E-mail: {linha[2]}")

    # 3. ATUALIZAR (Update)
    print("\n[U] - Atualizando o e-mail da Ana Costa...")
    cursor.execute("UPDATE Clientes SET email = ? WHERE nome = ?", ("ana.nova@email.com", "Ana Costa"))
    conexao.commit()
    print("✓ E-mail atualizado.")

    # 4. DELETAR (Delete)
    print("\n[D] - Deletando o registro do Carlos Souza...")
    cursor.execute("DELETE FROM Clientes WHERE nome = ?", ("Carlos Souza",))
    conexao.commit()
    print("✓ Registro removido.")

    # Fechando a conexão
    conexao.close()
    print("\n=== OPERAÇÕES CONCLUÍDAS ===")

if __name__ == "__main__":
    rodar_crud()