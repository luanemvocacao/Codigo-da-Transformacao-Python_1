# Modulo_12/atv1_test_soma.py
import unittest

# Função que realiza a operação de soma
def somar(a, b):
    return a + b

# Classe de teste que herda de unittest.TestCase
class TestSomaSimples(unittest.TestCase):
    
    def test_soma_positivos(self):
        """Testa a soma de dois números positivos."""
        self.assertEqual(somar(5, 3), 8)

    def test_soma_negativos(self):
        """Testa a soma de dois números negativos."""
        self.assertEqual(somar(-2, -3), -5)

    def test_soma_com_zero(self):
        """Testa a soma onde um dos valores é zero."""
        self.assertEqual(somar(0, 10), 10)

if __name__ == "__main__":
    unittest.main()