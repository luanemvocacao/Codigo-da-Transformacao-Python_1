
lista_compras = []

while True:
    print("\n=== LISTA DE COMPRAS ===")
    print(f"Itens atuais: {lista_compras if lista_compras else 'A lista está vazia.'}")
    print("------------------------")
    print("1. Adicionar item")
    print("2. Remover item")
    print("3. Sair")
    
    opcao = input("Escolha uma opção: ")
    
    if opcao == "1":
        item = input("Digite o nome do item para adicionar: ").strip()
        if item:
            lista_compras.append(item)
            print(f"'{item}' foi adicionado com sucesso!")
    elif opcao == "2":
        if not lista_compras:
            print("A lista já está vazia. Não há nada para remover.")
        else:
            item = input("Digite o nome do item para remover: ").strip()
            if item in lista_compras:
                lista_compras.remove(item)
                print(f"'{item}' foi removido com sucesso!")
            else:
                print(f"O item '{item}' não foi encontrado na lista.")
    elif opcao == "3":
        print("Programa encerrado. Boas compras!")
        break
    else:
        print("Opção inválida! Tente novamente.")