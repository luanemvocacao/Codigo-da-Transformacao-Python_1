# Conjunto inicial de números
numeros = [12, 7, 23, 44, 8, 15, 92, 31, 50]

pares = []
impares = []

# Percorrendo o conjunto com um loop for
for num in numeros:
    if num % 2 == 0:
        pares.append(num)
    else:
        impares.append(num)

# Exibindo as categorias separadamente
print(f"Lista original: {numeros}")
print(f"Números Pares:  {pares}")
print(f"Números Ímpares: {impares}")