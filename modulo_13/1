# Modulo_13/atv1_rota_get.py
from flask import Flask, jsonify # type: ignore

# Inicializa a aplicação Flask
app = Flask(__name__)

@app.route('/saudacao', methods=['GET'])
def obter_saudacao():
    """Implementa uma rota que retorna uma mensagem de saudação."""
    return jsonify({
        "status": "sucesso",
        "mensagem": "Olá! Seja bem-vindo à nossa API construída com Flask."
    }), 200

if __name__ == "__main__":
    # Executa o servidor em modo de desenvolvimento (debug)
    app.run(debug=True)